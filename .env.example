PMAS_API_KEY=
PMAS_LOG_LEVEL=INFO
PMAS_DEFAULT_PAGE_SIZE=30
PMAS_MAX_PAGE_SIZE=100
PMAS_NOTIFICATION_RETRY_COUNT=2
PMAS_NOTIFICATION_RETRY_BACKOFF_SECONDS=0.5

PMAS_SMTP_HOST=smtp.gmail.com
PMAS_SMTP_PORT=587
PMAS_SMTP_USER=your-user@example.com
PMAS_SMTP_PASSWORD=your-app-password
PMAS_SMTP_USE_TLS=true
PMAS_EMAIL_FROM=your-user@example.com

PMAS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PMAS_TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PMAS_TWILIO_FROM_PHONE=+1234567890
